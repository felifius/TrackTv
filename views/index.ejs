<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <div class="header">
        <div class="logo">🎬 TRACKTV</div>
        <form class="search-box" onsubmit="handleSearch(event)">
            <input 
                type="text" 
                id="searchInput" 
                placeholder="Buscar série ou filme..." 
                autocomplete="off"
            >
            <button type="submit" class="search-btn" title="Buscar">
                🔍
            </button>
        </form>
    </div>

    <div class="tabs">
        <div class="tab active" onclick="switchTab('watchlist')">
            📺 WATCH LIST
        </div>
        <div class="tab" onclick="switchTab('upcoming')">
            📅 PRÓXIMOS EPISÓDIOS
        </div>
        <div class="tab" onclick="switchTab('calendar')">
            📆 CALENDÁRIO
        </div>
    </div>

    <!-- Watch List Tab -->
    <div id="watchlist" class="tab-content active">
        <div class="watch-list">
            <div class="empty-state">
                <div class="empty-icon">📺</div>
                <div class="empty-text">Sua watch list está vazia</div>
                <div class="empty-subtext">Use a lupa para buscar e adicionar suas séries favoritas</div>
            </div>
        </div>
    </div>

    <!-- Upcoming Episodes Tab -->
    <div id="upcoming" class="tab-content">
        <div class="watch-list">
            <div class="empty-state">
                <div class="empty-icon">⏰</div>
                <div class="empty-text">Nenhum episódio próximo</div>
                <div class="empty-subtext">Adicione séries à sua watch list para ver os próximos lançamentos</div>
            </div>
        </div>
    </div>

    <!-- Calendar Tab -->
    <div id="calendar" class="tab-content">
        <div class="calendar">
            <div class="calendar-header">
                <button class="nav-btn" onclick="previousMonth()">← Anterior</button>
                <div class="month-year" id="monthYear"></div>
                <button class="nav-btn" onclick="nextMonth()">Próximo →</button>
            </div>
            <div class="weekdays">
                <div class="weekday">Dom</div>
                <div class="weekday">Seg</div>
                <div class="weekday">Ter</div>
                <div class="weekday">Qua</div>
                <div class="weekday">Qui</div>
                <div class="weekday">Sex</div>
                <div class="weekday">Sab</div>
            </div>
            <div class="days" id="calendarDays"></div>
        </div>
    </div>

    <script>
        let currentDate = new Date();

        function handleSearch(event) {
            event.preventDefault();
            const query = document.getElementById('searchInput').value.trim();
            
            if (query === '') {
                alert('Por favor, digite algo para buscar');
                return;
            }

            // Redireciona para a rota de busca
            window.location.href = `/search?q=${encodeURIComponent(query)}`;
        }

        function switchTab(tabName) {
            // Remove active de todos os tabs e conteúdos
            document.querySelectorAll('.tab').forEach(tab => tab.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));

            // Adiciona active ao tab e conteúdo selecionado
            event.target.classList.add('active');
            document.getElementById(tabName).classList.add('active');
        }

        function renderCalendar() {
            const year = currentDate.getFullYear();
            const month = currentDate.getMonth();

            // Atualizar cabeçalho
            const monthNames = ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho',
                'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'];
            document.getElementById('monthYear').textContent = `${monthNames[month]} ${year}`;

            // Obter primeiro dia do mês e número de dias
            const firstDay = new Date(year, month, 1).getDay();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            const daysInPrevMonth = new Date(year, month, 0).getDate();

            const calendarDays = document.getElementById('calendarDays');
            calendarDays.innerHTML = '';

            // Dias do mês anterior
            for (let i = firstDay - 1; i >= 0; i--) {
                const day = document.createElement('div');
                day.className = 'day other-month empty';
                day.textContent = daysInPrevMonth - i;
                calendarDays.appendChild(day);
            }

            // Dias do mês atual
            const today = new Date();
            for (let i = 1; i <= daysInMonth; i++) {
                const day = document.createElement('div');
                day.className = 'day';

                // Verificar se é hoje
                if (today.getFullYear() === year && 
                    today.getMonth() === month && 
                    today.getDate() === i) {
                    day.classList.add('today');
                }

                day.textContent = i;
                calendarDays.appendChild(day);
            }

            // Dias do próximo mês
            const totalCells = calendarDays.children.length;
            const remainingCells = 42 - totalCells; // 6 semanas * 7 dias
            for (let i = 1; i <= remainingCells; i++) {
                const day = document.createElement('div');
                day.className = 'day other-month empty';
                day.textContent = i;
                calendarDays.appendChild(day);
            }
        }

        function previousMonth() {
            currentDate.setMonth(currentDate.getMonth() - 1);
            renderCalendar();
        }

        function nextMonth() {
            currentDate.setMonth(currentDate.getMonth() + 1);
            renderCalendar();
        }

        // Inicializar calendário quando a página carregar
        document.addEventListener('DOMContentLoaded', () => {
            renderCalendar();
        });
    </script>
</body>
</html>
